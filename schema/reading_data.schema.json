{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/reading_data.schema.json",
  "title": "IELTS Reading HTML Generator Data",
  "type": "object",
  "additionalProperties": true,
  "required": ["title", "passages"],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "header_title": {"type": "string"},
    "header_sub": {"type": "string"},
    "passages": {
      "type": "array",
      "minItems": 1,
      "maxItems": 5,
      "description": "Supported counts are 1, 3, or 5 passages.",
      "items": {"$ref": "#/$defs/passage"}
    }
  },
  "$defs": {
    "paragraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "text"],
      "properties": {
        "label": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1}
      }
    },
    "heading_item": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["key", "text"],
          "properties": {
            "key": {"type": "string", "minLength": 1},
            "text": {"type": "string", "minLength": 1}
          }
        },
        {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "prefixItems": [
            {"type": "string", "minLength": 1},
            {"type": "string", "minLength": 1}
          ]
        }
      ]
    },
    "mcq": {
      "type": "object",
      "additionalProperties": true,
      "required": ["q", "type", "stem", "options", "answer"],
      "properties": {
        "q": {"type": "integer", "minimum": 1},
        "type": {"const": "mcq"},
        "stem": {"type": "string", "minLength": 1},
        "options": {"type": "array", "minItems": 2, "items": {"type": "string", "minLength": 1}},
        "answer": {"type": "string", "minLength": 1},
        "reveal": {"type": "string"}
      }
    },
    "tfng": {
      "type": "object",
      "additionalProperties": true,
      "required": ["q", "type", "statement", "answer"],
      "properties": {
        "q": {"type": "integer", "minimum": 1},
        "type": {"enum": ["tfng", "true_false"]},
        "statement": {"type": "string", "minLength": 1},
        "answer": {"enum": ["TRUE", "FALSE", "NOT GIVEN"]},
        "reveal": {"type": "string"}
      }
    },
    "ynng": {
      "type": "object",
      "additionalProperties": true,
      "required": ["q", "type", "statement", "answer"],
      "properties": {
        "q": {"type": "integer", "minimum": 1},
        "type": {"enum": ["ynng", "yes_no"]},
        "statement": {"type": "string", "minLength": 1},
        "answer": {"enum": ["YES", "NO", "NOT GIVEN"]},
        "reveal": {"type": "string"}
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": true,
      "required": ["q", "type", "text", "options", "answer"],
      "properties": {
        "q": {"type": "integer", "minimum": 1},
        "type": {"const": "match"},
        "text": {"type": "string", "minLength": 1},
        "options": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
        "answer": {"type": "string", "minLength": 1},
        "reveal": {"type": "string"}
      }
    },
    "fill": {
      "type": "object",
      "additionalProperties": true,
      "required": ["q", "type", "answer"],
      "properties": {
        "q": {"type": "integer", "minimum": 1},
        "type": {"const": "fill"},
        "before": {"type": "string"},
        "after": {"type": "string"},
        "answer": {"type": "string", "minLength": 1},
        "width": {"type": "integer", "minimum": 40},
        "reveal": {"type": "string"}
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": true,
      "required": ["q", "type", "pairs"],
      "properties": {
        "q": {"type": "integer", "minimum": 1},
        "type": {"const": "summary"},
        "pairs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 4,
            "prefixItems": [
              {"type": "integer", "minimum": 1},
              {"type": "string"},
              {"type": "string", "minLength": 1},
              {"type": "string"}
            ]
          }
        },
        "reveals": {"type": "array", "items": {"type": "string"}}
      }
    },
    "heading_info": {
      "type": "object",
      "additionalProperties": true,
      "required": ["q", "type"],
      "properties": {
        "q": {"type": "integer", "minimum": 1},
        "type": {"const": "heading_info"},
        "label": {"type": "string"},
        "reveal": {"type": "string"}
      }
    },
    "question_block": {
      "oneOf": [
        {"$ref": "#/$defs/mcq"},
        {"$ref": "#/$defs/tfng"},
        {"$ref": "#/$defs/ynng"},
        {"$ref": "#/$defs/match"},
        {"$ref": "#/$defs/fill"},
        {"$ref": "#/$defs/summary"},
        {"$ref": "#/$defs/heading_info"}
      ]
    },
    "questions": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "blocks"],
      "properties": {
        "type": {"enum": ["regular", "heading"]},
        "headings": {"type": "array", "items": {"$ref": "#/$defs/heading_item"}},
        "answers": {"type": "object", "additionalProperties": {"type": "string", "minLength": 1}},
        "blocks": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/question_block"}}
      }
    },
    "passage": {
      "type": "object",
      "additionalProperties": true,
      "required": ["num", "title", "paras", "questions"],
      "properties": {
        "num": {"type": "integer", "minimum": 1},
        "title": {"type": "string", "minLength": 1},
        "meta": {"type": "string"},
        "band": {"type": "string"},
        "genre": {"type": "string"},
        "paras": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/paragraph"}},
        "questions": {"$ref": "#/$defs/questions"}
      }
    }
  }
}
